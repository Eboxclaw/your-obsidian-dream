{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "ViBo default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-create-dir",
    "fs:allow-read-dir",
    "fs:allow-remove-file",
    "fs:allow-rename",
    "fs:allow-copy-file",
    "fs:allow-exists",
    "fs:allow-metadata",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "http:default",
    "http:allow-fetch",
    "biometric:default",
    "biometric:allow-authenticate",
    "biometric:allow-status",
    "leap-ai:default",
    "leap-ai:allow-download-model",
    "leap-ai:allow-load-model",
    "leap-ai:allow-unload-model",
    "leap-ai:allow-generate",
    "leap-ai:allow-create-conversation",
    "leap-ai:allow-list-cached-models",
    "leap-ai:allow-runtime-info"
  ]
}
