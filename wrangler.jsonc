{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "beta-vibo",
  "main": "src/worker.ts",
  "compatibility_date": "2026-03-18",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  }
}
